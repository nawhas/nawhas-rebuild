# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nawhas # gitguardian:ignore — dev-only default; real deployments must override via environment
DATABASE_POOL_MAX=10

# Better Auth
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated extra trusted origins (no trailing slash)
# Add your LAN IP when testing from other devices on the same network
# Example: BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.50.14:3000
BETTER_AUTH_TRUSTED_ORIGINS=

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key
# Read-only search key — safe to expose to the browser; admin key stays server-side
TYPESENSE_SEARCH_API_KEY=your-typesense-search-api-key

# S3-compatible Object Storage
# Dev: MinIO runs at http://localhost:9000 (console at http://localhost:9001)
# Prod: replace with real S3/R2/Backblaze credentials — no code changes needed
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_AUDIO=nawhas-audio
S3_BUCKET_IMAGES=nawhas-images
S3_PUBLIC_BASE_URL=http://localhost:9000/nawhas-audio

# Social OAuth — feature flags (set to 'true' to enable; credentials required when enabled)
# Google (P0 — global reach)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple (P0 — iOS App Store compliance)
# APPLE_PRIVATE_KEY is the .p8 key file content — Better Auth generates the JWT client secret internally
APPLE_OAUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_PRIVATE_KEY=

# Facebook (P1 — South Asia / Indonesia / Arab world)
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Microsoft / Entra ID (P2 — corporate/university accounts)
MICROSOFT_OAUTH_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Sentry Error Monitoring
# DSN is exposed to the browser — safe to commit (not a secret)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token used to upload source maps during production builds (keep secret)
SENTRY_AUTH_TOKEN=
# Sentry org/project slugs — used by withSentryConfig() in next.config.ts
SENTRY_ORG=
SENTRY_PROJECT=

# SMTP (transactional email)
# Dev: Mailpit catches all email at http://localhost:8025 — no credentials needed
# Prod: replace with real SMTP credentials (Postmark, Mailgun, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nawhas.com
SMTP_SECURE=false
