# SOPS — plaintext secrets must NEVER be committed; only *.yaml.enc files are safe
deploy/helm/nawhas/secrets/*.yaml
!deploy/helm/nawhas/secrets/*.yaml.enc
!deploy/helm/nawhas/secrets/*.yaml.example

# Helm subchart archives — downloaded at deploy time via `helm dependency build`
# Chart.lock is committed to pin versions; ArgoCD runs helm dep build automatically
deploy/helm/nawhas/charts/

# age private key files
*.key
