#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# ── Global flags ─────────────────────────────────────────────────────────────
#
# -T / --test   Append docker-compose.test.yml to every docker compose command.
#               Use this when you want the full test stack (nawhas_test DB,
#               nawhas.test alias, Typesense vars, etc.) without typing the full
#               -f flag chain.
#
#   ./dev up -d            → base stack only  (dev mode)
#   ./dev -T up -d         → base + test overlay (test mode)
#   ./dev -T db:seed       → seed nawhas_test
#   ./dev -T logs web -f   → tail web logs in test stack
#   ./dev down             → always uses all compose files (see cmd_down)
#
# test:e2e always uses the test overlay regardless of this flag.

COMPOSE_FILES="-f docker-compose.yml"

while [[ "${1:-}" =~ ^- ]]; do
  case "$1" in
    -T|--test)
      COMPOSE_FILES="-f docker-compose.yml -f docker-compose.test.yml"
      shift
      ;;
    --help|-h)
      # Let --help fall through to the usage display below
      break
      ;;
    *)
      # Not a global flag — stop parsing and treat as the command
      break
      ;;
  esac
done

# ── Helpers ─────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: ./dev [-T] <command> [args...]

Global flags
  -T, --test        Use docker-compose.test.yml overlay (test stack)

Special commands
  db:migrate        Run database migrations
  db:seed           Seed fixture data
  db:reset          Drop, migrate, and seed
  build             Production build
  lint              Run ESLint (Docker: web service, --no-deps)
  typecheck         TypeScript type check (Docker: web service, --no-deps)
  test              Run unit + integration tests (Docker + test DB overlay)
  qa                Typecheck, lint, and test in one Docker run (CI-friendly)
  test:e2e          Run E2E tests (always uses test overlay)
  test:e2e:ui       Run E2E tests in interactive Playwright UI
  test:e2e --ci     Run E2E tests with CI overrides
  smoke:prodlike    Run production-like Docker smoke checks for detail pages

Docker Compose pass-through
  Any other command is forwarded to docker compose (using active compose files).
  Examples:
    ./dev up -d              Start base dev stack
    ./dev -T up -d           Start test stack (creates nawhas_test DB)
    ./dev down               Stop all stacks (base + test + CI compose files; testing profile)
    ./dev -T down            Same as ./dev down (-T does not limit teardown)
    ./dev exec web bash      Shell into web container
    ./dev logs web -f        Tail web logs
    ./dev ps
EOF
}

require_docker() {
  if ! docker info > /dev/null 2>&1; then
    echo "Error: Docker is not running. Please start Docker and try again." >&2
    exit 1
  fi
}

check_hosts() {
  if ! grep -q "nawhas.test" /etc/hosts 2>/dev/null; then
    echo "Warning: nawhas.test is not in /etc/hosts."
    echo "  Add it with: echo '127.0.0.1 nawhas.test' | sudo tee -a /etc/hosts"
  fi
}

# All local compose overlays (same project name); used by cmd_down so one command
# tears down dev, test, and CI-shaped stacks regardless of which files were used for up.
ALL_COMPOSE_FILES=(
  -f docker-compose.yml
  -f docker-compose.test.yml
  -f docker-compose.ci.yml
)

cmd_down() {
  require_docker
  docker compose "${ALL_COMPOSE_FILES[@]}" --profile testing down "$@"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_db_migrate() {
  require_docker
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES exec web pnpm --filter @nawhas/db db:migrate
}

cmd_db_seed() {
  require_docker
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES exec -e SEED_MODERATOR_PASSWORD web pnpm --filter @nawhas/db db:seed
}

cmd_db_reset() {
  require_docker
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES exec web sh -c "pnpm --filter @nawhas/db db:drop && pnpm --filter @nawhas/db db:migrate && pnpm --filter @nawhas/db db:seed"
}

cmd_build() {
  require_docker
  # Run next build in a fresh throwaway container so it does not conflict with the
  # `next dev` process running in the web service container. Build @nawhas/types first
  # so its dist/ declarations exist when next build type-checks.
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES run --rm web sh -c "
    pnpm --filter @nawhas/types build &&
    pnpm --filter @nawhas/db build &&
    pnpm --filter @nawhas/web build
  "
}

# Lint / typecheck: no DB — avoid starting postgres/typesense via --no-deps.
# Install runs inside the container so a cold machine works without a prior `dev up`.
cmd_lint() {
  require_docker
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES run --rm --no-deps web sh -c "
    corepack enable &&
    pnpm install --frozen-lockfile &&
    pnpm run lint
  "
}

cmd_typecheck() {
  require_docker
  # shellcheck disable=SC2086
  docker compose $COMPOSE_FILES run --rm --no-deps web sh -c "
    corepack enable &&
    pnpm install --frozen-lockfile &&
    pnpm run typecheck
  "
}

# Tests: use test overlay (nawhas_test) and start stack deps so Postgres/Typesense match vitest env.
cmd_test() {
  require_docker
  docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm web sh -c "
    corepack enable &&
    pnpm install --frozen-lockfile &&
    pnpm --filter @nawhas/types build &&
    pnpm --filter @nawhas/db build &&
    pnpm --filter @nawhas/db db:migrate &&
    pnpm run test
  "
}

# One container, one install — use in CI instead of three separate Docker runs.
cmd_qa() {
  require_docker
  docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm web sh -c "
    corepack enable &&
    pnpm install --frozen-lockfile &&
    pnpm --filter @nawhas/types build &&
    pnpm --filter @nawhas/db build &&
    pnpm --filter @nawhas/db db:migrate &&
    pnpm run typecheck &&
    pnpm run lint &&
    pnpm run test
  "
}

cmd_test_e2e() {
  require_docker
  check_hosts
  local ci_env=""
  local use_ci_overlay=false
  for arg in "$@"; do
    if [[ "$arg" == "--ci" ]]; then
      ci_env="-e CI=true"
      use_ci_overlay=true
    fi
  done
  if [[ "${CI:-}" == "true" ]]; then
    ci_env="-e CI=true"
    use_ci_overlay=true
  fi
  # test:e2e: local uses base + docker-compose.test.yml (Playwright lives in the test overlay).
  # CI / --ci adds docker-compose.ci.yml (includes docker-compose.web-prod.yml) — same three -f chain as GHA E2E.
  #
  # Why port 3000 matters: docker-compose.yml publishes web as "3000:3000" so you can
  # open http://localhost:3000 on the host. Starting `web` requires binding host :3000.
  # If something else already listens there (pnpm/next dev on the host, another stack),
  # Docker errors with "address already in use". Free it: ./dev down, or stop the other
  # process (see docs/dev-setup.md — E2E and port 3000).
  #
  # Bring web up first (same as CI "Start stack"), then run Playwright with --no-deps so
  # we do not ask compose to reconcile `web` again in the same `run` invocation.
  local compose_e2e=(docker compose -f docker-compose.yml -f docker-compose.test.yml)
  if [[ "$use_ci_overlay" == "true" ]]; then
    compose_e2e=(
      docker compose
      -f docker-compose.yml
      -f docker-compose.test.yml
      -f docker-compose.ci.yml
    )
  fi
  "${compose_e2e[@]}" up -d --wait web
  # shellcheck disable=SC2086
  "${compose_e2e[@]}" --profile testing run --rm --no-deps $ci_env playwright
}

cmd_test_e2e_ui() {
  check_hosts
  pnpm --filter @nawhas/e2e test:e2e:ui
}

cmd_smoke_prodlike() {
  require_docker

  local reciter_slug="${RECITER_SLUG:-ali-safdar}"
  local album_slug="${ALBUM_SLUG:-panjtan-pak}"
  local seed_password="${SEED_MODERATOR_PASSWORD:-ci-test-moderator-password}"
  local compose_prod=(docker compose -f docker-compose.yml -f docker-compose.ci.yml)

  echo "Starting production-like stack (docker-compose + ci overlay)..."
  "${compose_prod[@]}" up -d --wait web

  echo "Seeding database fixtures..."
  SEED_MODERATOR_PASSWORD="$seed_password" cmd_db_seed

  echo "Running HTTP smoke checks..."
  local reciter_url="http://localhost:3000/reciters/${reciter_slug}"
  local album_url="http://localhost:3000/albums/${album_slug}"
  local reciter_code
  local album_code
  reciter_code="$(curl -s -o /dev/null -w "%{http_code}" "$reciter_url")"
  album_code="$(curl -s -o /dev/null -w "%{http_code}" "$album_url")"

  echo "  ${reciter_code} ${reciter_url}"
  echo "  ${album_code} ${album_url}"

  if [[ "$reciter_code" != "200" || "$album_code" != "200" ]]; then
    echo "Smoke check failed: expected HTTP 200 for both detail routes."
    return 1
  fi

  echo "Checking web logs for DYNAMIC_SERVER_USAGE..."
  local web_logs
  web_logs="$("${compose_prod[@]}" logs --no-color --tail=300 web || true)"
  if [[ "$web_logs" == *"DYNAMIC_SERVER_USAGE"* ]]; then
    echo "Smoke check failed: found DYNAMIC_SERVER_USAGE in web logs."
    return 1
  fi

  echo "Production-like smoke checks passed."
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  db:migrate)   cmd_db_migrate ;;
  db:seed)      cmd_db_seed ;;
  db:reset)     cmd_db_reset ;;
  build)        cmd_build ;;
  lint)         cmd_lint ;;
  typecheck)    cmd_typecheck ;;
  test)         cmd_test ;;
  qa)           cmd_qa ;;
  test:e2e:ui)  cmd_test_e2e_ui ;;
  test:e2e)     cmd_test_e2e "$@" ;;
  smoke:prodlike) cmd_smoke_prodlike ;;
  down)         cmd_down "$@" ;;
  --help|-h|"") usage ;;
  *)
    # Pass through to docker compose using the active compose files.
    require_docker
    # shellcheck disable=SC2086
    docker compose $COMPOSE_FILES "$COMMAND" "$@"
    ;;
esac
