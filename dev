#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# ── Helpers ─────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: ./dev <command> [args...]

Special commands
  db:migrate        Run database migrations
  db:seed           Seed fixture data
  db:reset          Drop, migrate, and seed
  build             Production build
  lint              Run ESLint
  typecheck         TypeScript type check
  test              Run unit tests (vitest)
  test:e2e          Run E2E tests (docker-compose.test.yml overlay)
  test:e2e:ui       Run E2E tests in interactive Playwright UI
  test:e2e --ci     Run E2E tests with CI overrides

Docker Compose pass-through
  Any other command is forwarded to docker compose.
  Examples:
    ./dev up -d
    ./dev down
    ./dev exec web bash
    ./dev logs web -f
    ./dev ps
    ./dev run --rm web pnpm lint
EOF
}

require_docker() {
  if ! docker info > /dev/null 2>&1; then
    echo "Error: Docker is not running. Please start Docker and try again." >&2
    exit 1
  fi
}

check_hosts() {
  if ! grep -q "nawhas.test" /etc/hosts 2>/dev/null; then
    echo "Warning: nawhas.test is not in /etc/hosts."
    echo "  Add it with: echo '127.0.0.1 nawhas.test' | sudo tee -a /etc/hosts"
  fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_db_migrate() {
  require_docker
  docker compose exec web pnpm --filter @nawhas/db db:migrate
}

cmd_db_seed() {
  require_docker
  docker compose exec web pnpm --filter @nawhas/db db:seed
}

cmd_db_reset() {
  require_docker
  docker compose exec web sh -c "pnpm --filter @nawhas/db db:drop && pnpm --filter @nawhas/db db:migrate && pnpm --filter @nawhas/db db:seed"
}

cmd_build() {
  require_docker
  docker compose exec web pnpm --filter @nawhas/web build
}

cmd_lint() {
  pnpm run lint
}

cmd_typecheck() {
  pnpm run typecheck
}

cmd_test() {
  pnpm run test
}

cmd_test_e2e() {
  require_docker
  check_hosts
  local ci_flag=""
  local ci_env=""
  for arg in "$@"; do
    if [[ "$arg" == "--ci" ]]; then
      ci_flag="--ci"
    fi
  done
  if [[ "${CI:-}" == "true" ]] || [[ "$ci_flag" != "" ]]; then
    ci_env="-e CI=true"
  fi
  # shellcheck disable=SC2086
  docker compose -f docker-compose.yml -f docker-compose.test.yml --profile testing run --rm $ci_env playwright
}

cmd_test_e2e_ui() {
  check_hosts
  pnpm --filter @nawhas/e2e test:e2e:ui
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  db:migrate)   cmd_db_migrate ;;
  db:seed)      cmd_db_seed ;;
  db:reset)     cmd_db_reset ;;
  build)        cmd_build ;;
  lint)         cmd_lint ;;
  typecheck)    cmd_typecheck ;;
  test)         cmd_test ;;
  test:e2e:ui)  cmd_test_e2e_ui ;;
  test:e2e)     cmd_test_e2e "$@" ;;
  --help|-h|"") usage ;;
  *)
    # Pass through to docker compose with standard compose files
    require_docker
    docker compose "$COMMAND" "$@"
    ;;
esac
