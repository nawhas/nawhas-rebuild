{
  "name": "@nawhas/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./typesense/admin-client": {
      "import": "./dist/typesense/admin-client.js",
      "types": "./dist/typesense/admin-client.d.ts"
    },
    "./typesense/collections": {
      "import": "./dist/typesense/collections.js",
      "types": "./dist/typesense/collections.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "typecheck": "tsc --build --noEmit",
    "lint": "eslint src",
    "db:generate": "tsc --build && drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/seed.ts",
    "db:seed": "tsx src/seed.ts",
    "db:search-index": "tsx src/search-index-cli.ts",
    "db:typesense-ensure": "tsx src/typesense-ensure-cli.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "typesense": "^2.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@nawhas/config": "workspace:*",
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
