# ============================================================
# Nawhas.com Environment Variables
# ============================================================
# Copy this file to .env and fill in values for local dev.
# In production/staging, all secrets are managed via SOPS-encrypted
# Helm values (deploy/helm/nawhas/secrets/*.yaml.enc) — never .env.
#
# Required = app will not start without this.
# Optional = has a sensible default; only set to override.
# ============================================================

# ------------------------------------------------------------
# Database (REQUIRED)
# ------------------------------------------------------------
# PostgreSQL connection string.
# Dev default: see docker-compose.yml (postgres service).
# Staging/prod: set via SOPS-encrypted Helm secret — see deploy/helm/nawhas/secrets/staging.yaml.example
DATABASE_URL=postgresql://postgres:password@localhost:5432/nawhas

# ------------------------------------------------------------
# Authentication (REQUIRED)
# ------------------------------------------------------------
# better-auth secret — MUST be a long random string in production.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production-use-a-long-random-secret

# Public-facing URL of the application (no trailing slash).
BETTER_AUTH_URL=http://nawhas.test:3000

# Comma-separated list of trusted origins for CORS / CSRF protection.
BETTER_AUTH_TRUSTED_ORIGINS=http://nawhas.test:3000,http://localhost:3000

# ------------------------------------------------------------
# Search — Typesense (REQUIRED)
# ------------------------------------------------------------
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=nawhas-typesense-key

# ------------------------------------------------------------
# Object Storage — S3-compatible (REQUIRED)
# ------------------------------------------------------------
# Endpoint URL of the S3-compatible service.
# Dev: MinIO running in Docker Compose (http://minio:9000 inside Docker, http://localhost:9000 from host).
# Prod: set to your S3 provider endpoint.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Bucket names (created automatically by minio-init in dev)
S3_BUCKET_AUDIO=nawhas-audio
S3_BUCKET_IMAGES=nawhas-images

# Public base URL for serving audio files (no trailing slash).
# Dev: http://localhost:9000/nawhas-audio
# Prod: https://cdn.nawhas.com/nawhas-audio (or your CDN)
S3_PUBLIC_BASE_URL=http://localhost:9000/nawhas-audio

# ------------------------------------------------------------
# Email / SMTP (OPTIONAL in dev — required in production)
# ------------------------------------------------------------
# Dev: Mailpit SMTP trap (docker-compose.yml)
# Staging: MailHog SMTP trap (K8s mailhog service)
# Prod: real SMTP provider (SendGrid, SES, Postmark, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nawhas.com
# Set to "true" for TLS connections (port 465 / SMTPS). False for STARTTLS or unencrypted.
SMTP_SECURE=false

# ------------------------------------------------------------
# Error Monitoring — Sentry (OPTIONAL — production recommended)
# ------------------------------------------------------------
# Public DSN — safe to expose to the browser.
# Leave blank to disable Sentry entirely.
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for uploading source maps. Set in CI only — never in .env.
SENTRY_AUTH_TOKEN=

# Sentry org and project slugs (CI only)
SENTRY_ORG=
SENTRY_PROJECT=

# ------------------------------------------------------------
# CDN (OPTIONAL — production recommended)
# ------------------------------------------------------------
# Hostname (no protocol) of your CDN for Next.js image optimisation.
# Example: cdn.nawhas.com
# Leave blank in dev.
NEXT_PUBLIC_CDN_HOSTNAME=

# ------------------------------------------------------------
# Bundle Analyzer (OPTIONAL — dev/CI only)
# ------------------------------------------------------------
# Set to "true" to open the bundle analyser after next build.
ANALYZE=false

# ------------------------------------------------------------
# CI-only GitHub Actions secrets (not used by the app)
# ------------------------------------------------------------
# These are stored in GitHub Actions secrets, not in .env.
# Documented here for reference only.
#
# ARGOCD_SERVER   — ArgoCD server hostname (no https://)
# ARGOCD_USERNAME — ArgoCD login username (default: admin)
# ARGOCD_PASSWORD — ArgoCD login password
