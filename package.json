{
  "name": "nawhas",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:e2e": "docker compose --profile testing run --rm playwright",
    "db:seed": "pnpm --filter @nawhas/db db:seed",
    "perf:lighthouse": "lhci autorun",
    "perf:k6": "k6 run apps/web/perf/k6/scripts/smoke.js"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "eslint": "^10.2.1",
    "turbo": "^2.9.6",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=8.0.5",
      "esbuild": ">=0.25.0",
      "tmp": ">=0.2.4"
    }
  },
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22"
  }
}
