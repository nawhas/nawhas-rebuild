# STAGING SECRETS TEMPLATE
#
# Copy this file to staging.yaml, fill in real values, then encrypt:
#   sops --encrypt staging.yaml > staging.yaml.enc
#
# The plaintext staging.yaml is blocked by .gitignore and must NEVER be committed.
# Only staging.yaml.enc (SOPS-encrypted) is safe to commit.

app:
  # In-cluster PostgreSQL (Bitnami subchart) — the subchart reads POSTGRES_PASSWORD from
  # this secret (see values-staging.yaml postgresql.auth.existingSecret). Set this to the
  # same password used in DATABASE_URL.
  # Generate: openssl rand -base64 32
  POSTGRES_PASSWORD: ""  # gitguardian:ignore
  DATABASE_URL: "postgresql://nawhas:CHANGE_ME@nawhas-postgresql.nawhas-staging.svc.cluster.local:5432/nawhas"
  BETTER_AUTH_SECRET: "CHANGE_ME_USE_LONG_RANDOM_SECRET"
  BETTER_AUTH_URL: "https://staging.nawhas.cititech.tech"
  BETTER_AUTH_TRUSTED_ORIGINS: "https://staging.nawhas.cititech.tech"
  TYPESENSE_API_KEY: "CHANGE_ME"
  # MinIO root credentials — these are also used as the S3 access key/secret for the app.
  # Generate: openssl rand -hex 16
  MINIO_ROOT_USER: "CHANGE_ME"
  MINIO_ROOT_PASSWORD: "CHANGE_ME"
  S3_ACCESS_KEY_ID: "CHANGE_ME"       # set to same value as MINIO_ROOT_USER
  S3_SECRET_ACCESS_KEY: "CHANGE_ME"   # set to same value as MINIO_ROOT_PASSWORD
  S3_PUBLIC_BASE_URL: "https://s3.staging.nawhas.cititech.tech/nawhas-audio"
  SENTRY_AUTH_TOKEN: "CHANGE_ME"
  NEXT_PUBLIC_SENTRY_DSN: "CHANGE_ME"
