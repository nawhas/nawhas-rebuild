# STAGING SECRETS TEMPLATE
#
# Copy this file to staging.yaml, fill in real values, then encrypt:
#   sops --encrypt staging.yaml > staging.yaml.enc
#
# The plaintext staging.yaml is blocked by .gitignore and must NEVER be committed.
# Only staging.yaml.enc (SOPS-encrypted) is safe to commit.

app:
  DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgres:5432/nawhas"
  BETTER_AUTH_SECRET: "CHANGE_ME_USE_LONG_RANDOM_SECRET"
  BETTER_AUTH_URL: "https://staging.nawhas.cititech.tech"
  BETTER_AUTH_TRUSTED_ORIGINS: "https://staging.nawhas.cititech.tech"
  TYPESENSE_API_KEY: "CHANGE_ME"
  S3_ACCESS_KEY_ID: "CHANGE_ME"
  S3_SECRET_ACCESS_KEY: "CHANGE_ME"
  S3_PUBLIC_BASE_URL: "https://s3.staging.nawhas.cititech.tech/nawhas-audio"
  SENTRY_AUTH_TOKEN: "CHANGE_ME"
  NEXT_PUBLIC_SENTRY_DSN: "CHANGE_ME"
