# PRODUCTION SECRETS TEMPLATE
#
# Copy this file to production.yaml, fill in real values, then encrypt:
#   sops --encrypt production.yaml > production.yaml.enc
#
# The plaintext production.yaml is blocked by .gitignore and must NEVER be committed.
# Only production.yaml.enc (SOPS-encrypted) is safe to commit.

app:
  DATABASE_URL: "postgresql://postgres:CHANGE_ME@postgres:5432/nawhas"
  BETTER_AUTH_SECRET: "CHANGE_ME_USE_LONG_RANDOM_SECRET"
  BETTER_AUTH_URL: "https://nawhas.com"
  BETTER_AUTH_TRUSTED_ORIGINS: "https://nawhas.com"
  TYPESENSE_API_KEY: "CHANGE_ME"
  S3_ACCESS_KEY_ID: "CHANGE_ME"
  S3_SECRET_ACCESS_KEY: "CHANGE_ME"
  S3_PUBLIC_BASE_URL: "https://cdn.nawhas.com/nawhas-audio"
  SENTRY_AUTH_TOKEN: "CHANGE_ME"
  NEXT_PUBLIC_SENTRY_DSN: "CHANGE_ME"
  SMTP_HOST: "CHANGE_ME"
  SMTP_PORT: "587"
  SMTP_USER: "CHANGE_ME"
  SMTP_PASS: "CHANGE_ME"
  SMTP_FROM: "noreply@nawhas.com"
  SMTP_SECURE: "true"
